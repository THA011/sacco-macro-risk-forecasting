# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/

# --- Environment / secrets ---
.env
*.env.local

# --- Data (never commit real or generated data, even synthetic) ---
data/raw/*
data/external/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/external/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# --- Model artifacts ---
*.pkl
*.joblib
models_saved/

# --- Reports ---
reports/figures/*
!reports/figures/.gitkeep

# --- OS / editor ---
.DS_Store
.vscode/settings.json
